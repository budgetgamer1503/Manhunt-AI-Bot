{
	"format_version": "1.21.40",
	"minecraft:client_entity": {
		"description": {
			"identifier": "manhunt:hunter",
			"materials": {
				"default": "entity_alphatest",
				"humanoid": "entity_alphatest",
				"humanoid_armor": "entity_alphatest"
			},
			"textures": {
				"steve": "textures/entity/hunter/steve",
				"alex": "textures/entity/hunter/alex",
				"zombie": "textures/entity/hunter/zombie",
				"skeleton": "textures/entity/hunter/skeleton",
				"creeper": "textures/entity/hunter/creeper",
				"custom": "textures/entity/hunter/custom",
				"dream": "textures/entity/hunter/dream",
				"technoblade": "textures/entity/hunter/technoblade",
				"armor_empty": "textures/entity/hunter/armor_empty"
			},
			"geometry": {
				"default": "geometry.manhunt.hunter",
				"armor_helmet": "geometry.player.armor.helmet",
				"armor_chestplate": "geometry.player.armor.chestplate",
				"armor_leggings": "geometry.player.armor.leggings",
				"armor_boots": "geometry.player.armor.boots"
			},
			"animations": {
				"humanoid_base_pose": "animation.humanoid.base_pose",
				"look_at_target": "animation.humanoid.look_at_target.default",
				"walk": "animation.humanoid.move",
				"bob": "animation.humanoid.bob",
				"damage": "animation.humanoid.damage",
				"riding": "animation.humanoid.riding",
				"swimming": "animation.humanoid.swimming",
				"attack": "animation.humanoid.attack.rotations",
				"holding": "animation.humanoid.holding",
				"brandish_spear": "animation.humanoid.brandish_spear",
				"charging": "animation.humanoid.charging",
				"sneaking": "animation.humanoid.sneaking"
			},
			"scripts": {
				"initialize": [
					"variable.is_holding_right = 0.0;",
					"variable.is_holding_left = 0.0;",
					"variable.is_blinking = 0.0;",
					"variable.last_blink_time = 0.0;",
					"variable.hand_bob = 0.0;",
					"variable.attack_time = 0.0;"
				],
				"pre_animation": [
					"variable.tcos0 = (math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / 1.0) * 57.3;",
					"variable.is_holding_right = query.is_item_name_any('slot.weapon.mainhand', 0) ? 1.0 : 0.0;",
					"variable.is_holding_left = query.is_item_name_any('slot.weapon.offhand', 0) ? 1.0 : 0.0;",
					"variable.attack_time = query.is_delayed_attacking ? 1.0 : 0.0;"
				],
				"animate": [
					"humanoid_base_pose",
					"look_at_target",
					{
						"walk": "query.modified_move_speed>0"
					},
					{
						"bob": "query.modified_move_speed>0"
					},
					{
						"swimming": "query.is_swimming"
					},
					{
						"attack": "query.any_animation_finished||variable.attack_time>0"
					},
					{
						"holding": "variable.is_holding_right>0||variable.is_holding_left>0"
					},
					{
						"sneaking": "query.is_sneaking"
					}
				]
			},
			"render_controllers": [
				"controller.render.manhunt_hunter",
				"controller.render.manhunt_hunter_armor"
			],
			"spawn_egg": {
				"base_color": "#8B0000",
				"overlay_color": "#FFD700"
			},
			"enable_attachables": true
		}
	}
}